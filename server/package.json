{
  "name": "collab-code-editor-server",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone WebSocket server for the collaborative code editor",
  "main": "index.js",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node index.js",
    "start": "node index.js",
    "dev:cluster": "concurrently -k -n inst-8080,inst-8081 -c blue,magenta \"PORT=8080 node index.js\" \"PORT=8081 node index.js\"",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:test": "node scripts/testDbConnection.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "pg": "^8.22.0",
    "ws": "^8.18.0",
    "y-websocket": "^1.5.4",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "concurrently": "^9.2.3",
    "prisma": "^7.8.0"
  }
}
