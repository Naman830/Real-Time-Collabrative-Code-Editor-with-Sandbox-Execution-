# URL of the standalone y-websocket sync server (see ../server).
# Points at localhost for local dev; swap for the deployed Railway/Render URL in production.
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# URL of the standalone code-execution service (see ../exec-server), which itself
# proxies to Piston. Points at localhost for local dev; swap for the deployed
# Railway/Render URL in production.
EXEC_SERVER_API_URL=http://localhost:4000
